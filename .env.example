# ===========================================================================
# Smerio Telegram Bot Environment Configuration Template
# Copy this file to '.env' and fill in your actual keys.
# ===========================================================================

# Bot Identifiers (to support multiple bots in the same AWS account without collision)
BOT_ID=smerio_bot_1

# Telegram Bot API Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Smerio Standalone Application Access Configuration
SMERIO_API_URL=http://localhost:8090
SMERIO_TELEGRAM_TOKEN=smerio_tg_secret_gateway_token_here

# Zero-Trust Security Configuration (Allowed numeric Telegram user ID)
ALLOWED_TELEGRAM_USER_ID=5139816564

# LLM Advisor & Parsing Configuration
# Options: 'gemini' | 'claude' | 'openai'
LLM_PROVIDER=gemini
LLM_API_KEY=your_llm_provider_api_key_here
